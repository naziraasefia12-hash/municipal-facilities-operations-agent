# ─── AI Agent ────────────────────────────────────────────────────────────────
# Gemini API key — leave blank to use the deterministic rule-based fallback
GEMINI_API_KEY=

# Gemini model name. Change to a newer model without touching code.
GEMINI_MODEL=gemini-1.5-flash

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to the backend/ directory)
DATABASE_URL=sqlite:///./municipal_facilities.db

# ─── Application ──────────────────────────────────────────────────────────────
# Set to "test" to suppress seed data during automated tests
APP_ENV=development
